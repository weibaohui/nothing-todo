    "antd": "^6.3.6",
    "axios": "^1.15.2",
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "react-js-cron": "^6.0.2"
  },
  "devDependencies": {
