{
  "$schema": "https://v2.tauri.app/schemas/config.schema.json",
  "productName": "ntd",
  "version": "0.1.0",
  "identifier": "com.ntd.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [{
      "title": "ntd - Nothing Todo",
      "width": 1200,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "center": true
    }],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
  },
  "plugins": {
    "shell": { "open": true }
  }
}